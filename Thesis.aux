\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces 同一条 $A\!\rightarrow \!B\!\rightarrow \!C$ 算子链的三种执行映射。 (a)\nobreakspace  {}多 kernel 以物理 grid completion 排序阶段，并在边界处物化中间结果； (b)\nobreakspace  {}传统融合消去 $A$--$B$ 物理边界，但 worker 仍执行静态融合程序，且 $C$ 前仍保留物理边界； (c)\nobreakspace  {}persistent Megakernel 仅 launch 一次，由设备端调度维护 queue/event/counter，worker 拉取 tile 任务： tile-ready 允许 $B_0$ 与 $A$ 尾部重叠，而 $C$ 前的 all-ready 则表现为内部 readiness gate。 Megakernel 中间结果是否落 HBM 取决于具体实现，图中不作约定。\relax }}{2}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:megakernel-principle}{{1}{2}{同一条 $A\!\rightarrow \!B\!\rightarrow \!C$ 算子链的三种执行映射。 (a)~多 kernel 以物理 grid completion 排序阶段，并在边界处物化中间结果； (b)~传统融合消去 $A$--$B$ 物理边界，但 worker 仍执行静态融合程序，且 $C$ 前仍保留物理边界； (c)~persistent Megakernel 仅 launch 一次，由设备端调度维护 queue/event/counter，worker 拉取 tile 任务： tile-ready 允许 $B_0$ 与 $A$ 尾部重叠，而 $C$ 前的 all-ready 则表现为内部 readiness gate。 Megakernel 中间结果是否落 HBM 取决于具体实现，图中不作约定。\relax }{figure.caption.2}{}}
\citation{nvidia2026pdl,nvidia2026cutlassDependentLaunch}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Hazy \texttt  {PartialAttention}$\rightarrow $\texttt  {O\_ProjResidual} 的 SM--时间执行结构。Early-Inside 中，queues 8--131 在 32 个 query heads 全量就绪前进入 consumer 路径，形成 pre-ready residence interval；Serial-Split 由 producer grid completion 统一放行 consumer grid。两种方案保持 task code、queue mapping、task/noop slots 和 instruction bytes 一致。橙色区间对应后续 admission-gated 对照与设备端时间戳所分解的关键阶段。\relax }}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:hazy-boundary}{{2}{3}{Hazy \texttt {PartialAttention}$\rightarrow $\texttt {O\_ProjResidual} 的 SM--时间执行结构。Early-Inside 中，queues 8--131 在 32 个 query heads 全量就绪前进入 consumer 路径，形成 pre-ready residence interval；Serial-Split 由 producer grid completion 统一放行 consumer grid。两种方案保持 task code、queue mapping、task/noop slots 和 instruction bytes 一致。橙色区间对应后续 admission-gated 对照与设备端时间戳所分解的关键阶段。\relax }{figure.caption.3}{}}
